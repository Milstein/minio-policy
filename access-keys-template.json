{
 "Version": "2012-10-17",
 "Statement": [
  {
   "Effect": "Allow",
   "Action": [
    "s3:GetObject",
    "s3:ListBucket"
   ],
   "Resource": [
    "arn:aws:s3:::my-storage",
    "arn:aws:s3:::my-storage/*"
   ]
  },
  {
   "Effect": "Deny",
   "Action": [
    "s3:DeleteObject",
    "s3:PutObject"
   ],
   "Resource": [
    "arn:aws:s3:::my-storage/*"
   ]
  },
  {
   "Effect": "Allow",
   "Action": [
    "s3:ListBucket",
    "s3:PutObject",
    "s3:DeleteObject",
    "s3:GetBucketLocation",
    "s3:GetObject"
   ],
   "Resource": [
    "arn:aws:s3:::group1-bucket",
    "arn:aws:s3:::group1-bucket/*"
   ]
  }
 ]
}